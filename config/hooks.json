{
  "hooks": {
    "preRoute": [
      "scripts/validate.sh",
      "scripts/check_policy_gate.sh"
    ],
    "postRoute": [
      "scripts/log_plan.sh"
    ],
    "onFailure": [
      "python3 scripts/self_heal.py"
    ],
    "scheduled": {
      "selfEvolveEveryTicks": 5,
      "command": "python3 scripts/self_evolve.py"
    }
  }
}
