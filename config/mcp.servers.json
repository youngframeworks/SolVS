{
  "_readme": "Override Foundry Local endpoint with env var FOUNDRY_LOCAL_ENDPOINT, e.g. FOUNDRY_LOCAL_ENDPOINT=http://host:5272",
  "servers": [
    {
      "id": "filesystem",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    {
      "id": "github",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    {
      "id": "foundry-local",
      "transport": "http",
      "url": "http://127.0.0.1:5272",
      "acceptedStatus": [200, 404]
    }
  ]
}
