{
  "rules": [
    {
      "id": "quick-tasks",
      "matchAny": ["quick", "small", "fast", "short", "trivial"],
      "route": ["QuickTasksAgent"]
    },
    {
      "id": "coding-tasks",
      "matchAny": ["code", "implement", "refactor", "bug", "feature", "unit test"],
      "route": ["CodingAgent"]
    },
    {
      "id": "complex-tasks",
      "matchAny": ["architecture", "complex", "research", "design", "strategy", "optimize"],
      "route": ["CopilotProAgent"]
    },
    {
      "id": "architecture-review",
      "matchAny": ["architecture", "drift", "governance", "review"],
      "route": ["SolManager", "SolOSReviewer"]
    },
    {
      "id": "feature-implementation",
      "matchAny": ["feature", "implement", "build", "create"],
      "route": ["SolOSRouter", "SolOSImplementer", "SolOSReviewer"]
    },
    {
      "id": "ops-or-runtime",
      "matchAny": ["runtime", "sysops", "deploy", "health", "diagnostic"],
      "route": ["SolOSRouter", "SolOSSysOps", "SolOSReviewer"]
    },
    {
      "id": "self-heal",
      "matchAny": ["self-heal", "heal", "fix drift", "repair"],
      "route": ["SolManager"]
    },
    {
      "id": "self-evolve",
      "matchAny": ["self-evolve", "evolve", "optimize prompts", "improve workflow"],
      "route": ["SolManager"]
    }
  ],
  "fallbackRoute": ["SolOSRouter", "SolOSImplementer", "SolOSReviewer"]
}
